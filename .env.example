# Project-level model runtime settings (do not commit real keys)
OPENAI_API_KEY=

# Optional: override stage providers from run_config (deterministic | openai | openai-compatible)
SHOTGUNCV_GENERATOR_PROVIDER=
SHOTGUNCV_JUDGE_PROVIDER=

# Optional: stage-specific model override
SHOTGUNCV_GENERATOR_MODEL=
SHOTGUNCV_JUDGE_MODEL=

# Optional: shared model override when stage-specific model is empty
# If all model settings are empty, defaults to gpt-5.4-mini.
OPENAI_MODEL=

# Optional: OpenAI-compatible base URL.
# Keep empty for the official endpoint https://api.openai.com/v1
OPENAI_BASE_URL=

# Optional: override api key variable name in this .env
OPENAI_API_KEY_ENV=
